# Copy this file to `.env` and fill in your real values before running the app.
# Keep the same `SUPABASE_URL` and `SUPABASE_KEY` across machines to use the same Supabase project.

FLASK_APP=app.py
FLASK_ENV=development
SECRET_KEY=changeme

# Supabase (fill with your project values)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# If you use a direct Postgres connection for migrations or other back-end work
DATABASE_URL=postgresql://user:password@host:5432/database

# Optional: backend URL if hosted separately
BACKEND_URL=http://localhost:5000
